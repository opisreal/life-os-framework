<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyLists-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.lifeos.finance.yearly</string>
    <key>ProgramArguments</key>
    <array>
        <string>/Users/USERNAME/life-os/05_finance/_tools/yearly-reminder.sh</string>
    </array>
    <key>StartCalendarInterval</key>
    <dict>
        <key>Month</key>  <integer>1</integer>
        <key>Day</key>    <integer>8</integer>
        <key>Hour</key>   <integer>9</integer>
        <key>Minute</key> <integer>0</integer>
    </dict>
    <key>StandardOutPath</key>
    <string>/tmp/life-os-launchd.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/life-os-launchd.log</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>
</dict>
</plist>
