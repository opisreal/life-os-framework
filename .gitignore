# Obsidian 工作区状态（每次打开都变，不适合版本控制）
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/cache
.trash/

# 系统文件
.DS_Store
Thumbs.db

# 私密内容（强约定）
**/*.private.md
**/secrets.md

# 通知基础设施配置（含 webhook / token）
.tools/notify.config.private.json

# Claude Code 中的敏感配置
.claude/skills/**/endpoints.json
.claude/skills/**/audit.log
.claude/skills/**/*.secret.*

# 工具副本与临时目录
.agents/
_temp/

# Python 字节码缓存
__pycache__/

# 通知/提醒脚本运行日志
.tools/logs/*.log
.tools/.env.private
